@the_party
on-arrival: {!
// Per-quarter seat calculations using per-quarter faction strengths
var qPcts = [0.20, 0.15, 0.25, 0.20, 0.10, 0.10];
Q.km_congress_seats = 0;
Q.lk_congress_seats = 0;
Q.ok_congress_seats = 0;
Q.rk_congress_seats = 0;

function _qLabel(v) {
    if (v < 0.5) return "Nonexistent";
    if (v < 1.5) return "Very Weak";
    if (v < 2.5) return "Weak";
    if (v < 3.5) return "Medium";
    if (v < 4.5) return "Strong";
    return "Very Strong";
}

for (var qi = 0; qi < qPcts.length; qi++) {
    var qSeats = Math.round(qPcts[qi] * 1200);
    var qTotal = (Q['q' + qi + '_km_str'] || 0) + (Q['q' + qi + '_lk_str'] || 0) + (Q['q' + qi + '_ok_str'] || 0);
    if (!Q.right_kemalist_split) {
        qTotal += (Q['q' + qi + '_rk_str'] || 0);
    }
    if (qTotal <= 0) qTotal = 1;

    Q['q' + qi + '_total'] = qSeats;
    Q['q' + qi + '_km'] = Math.round(qSeats * (Q['q' + qi + '_km_str'] || 0) / qTotal);
    Q['q' + qi + '_lk'] = Math.round(qSeats * (Q['q' + qi + '_lk_str'] || 0) / qTotal);
    Q['q' + qi + '_ok'] = Math.round(qSeats * (Q['q' + qi + '_ok_str'] || 0) / qTotal);
    Q['q' + qi + '_rk'] = Q.right_kemalist_split ? 0 : Math.round(qSeats * (Q['q' + qi + '_rk_str'] || 0) / qTotal);

    // Per-quarter strength text labels
    Q['q' + qi + '_km_label'] = _qLabel(Q['q' + qi + '_km_str'] || 0);
    Q['q' + qi + '_lk_label'] = _qLabel(Q['q' + qi + '_lk_str'] || 0);
    Q['q' + qi + '_ok_label'] = _qLabel(Q['q' + qi + '_ok_str'] || 0);
    Q['q' + qi + '_rk_label'] = Q.right_kemalist_split ? "Nonexistent" : _qLabel(Q['q' + qi + '_rk_str'] || 0);

    // Accumulate total seats from per-quarter results
    Q.km_congress_seats += Q['q' + qi + '_km'];
    Q.lk_congress_seats += Q['q' + qi + '_lk'];
    Q.ok_congress_seats += Q['q' + qi + '_ok'];
    Q.rk_congress_seats += Q['q' + qi + '_rk'];
}

// Adjust rounding to ensure total is exactly 1200
var seat_diff = 1200 - (Q.km_congress_seats + Q.lk_congress_seats + Q.ok_congress_seats + Q.rk_congress_seats);
if (seat_diff !== 0) {
    var maxSeats = Math.max(Q.km_congress_seats, Q.lk_congress_seats, Q.ok_congress_seats, Q.rk_congress_seats);
    if (Q.lk_congress_seats === maxSeats) {
        Q.lk_congress_seats += seat_diff;
    } else if (Q.ok_congress_seats === maxSeats) {
        Q.ok_congress_seats += seat_diff;
    } else if (Q.rk_congress_seats === maxSeats) {
        Q.rk_congress_seats += seat_diff;
    } else {
        Q.km_congress_seats += seat_diff;
    }
}

// Calculate candidate seats
Q.candidate_1_seats = 0;
Q.candidate_2_seats = 0;
if (Q.congress_upcoming) {
    if (Q.kemalist_marxists_support == 1) Q.candidate_1_seats += Q.km_congress_seats;
    if (Q.kemalist_marxists_support == 2) Q.candidate_2_seats += Q.km_congress_seats;
    if (Q.left_kemalists_support == 1) Q.candidate_1_seats += Q.lk_congress_seats;
    if (Q.left_kemalists_support == 2) Q.candidate_2_seats += Q.lk_congress_seats;
    if (Q.orthodox_kemalists_support == 1) Q.candidate_1_seats += Q.ok_congress_seats;
    if (Q.orthodox_kemalists_support == 2) Q.candidate_2_seats += Q.ok_congress_seats;
    if (!Q.right_kemalist_split) {
        if (Q.right_kemalists_support == 1) Q.candidate_1_seats += Q.rk_congress_seats;
        if (Q.right_kemalists_support == 2) Q.candidate_2_seats += Q.rk_congress_seats;
    }
}

// Determine outline colors based on candidate support
function getOutline(support) {
    if (!Q.congress_upcoming) return "none";
    if (support == 1) return "#ca1010";
    if (support == 2) return "#9e9e9e";
    return "none";
}

// Build parliament data for d3 rendering
var pData = [];
if (Q.km_congress_seats > 0) {
    pData.push({ id: "km", legend: "Kemalist Marxists", name: "KM", seats: Q.km_congress_seats, color: "#701616", outline: getOutline(Q.kemalist_marxists_support) });
}
if (Q.lk_congress_seats > 0) {
    pData.push({ id: "lk", legend: "Left Kemalists", name: "LK", seats: Q.lk_congress_seats, color: "#c76082", outline: getOutline(Q.left_kemalists_support) });
}
if (Q.ok_congress_seats > 0) {
    pData.push({ id: "ok", legend: "Orthodox Kemalists", name: "OK", seats: Q.ok_congress_seats, color: "#5a5f63", outline: getOutline(Q.orthodox_kemalists_support) });
}
if (!Q.right_kemalist_split && Q.rk_congress_seats > 0) {
    pData.push({ id: "rk", legend: "Right Kemalists", name: "RK", seats: Q.rk_congress_seats, color: "#353057", outline: getOutline(Q.right_kemalists_support) });
}
window.partyParliamentData = pData;

// Build candidate support text
// Faction support values: 0 = undecided, 1 = candidate_1, 2 = candidate_2
// Set these in any on-arrival block to change faction backing, e.g.:
//   Q.kemalist_marxists_support = 1;  // back candidate 1
//   Q.orthodox_kemalists_support = 0; // withdraw support
Q.candidate_1_supporters = "";
Q.candidate_2_supporters = "";
Q.undecided_factions = "";
if (Q.congress_upcoming) {
    var s1 = [], s2 = [], su = [];
    if (Q.left_kemalists_support == 1) s1.push("Left Kemalists");
    else if (Q.left_kemalists_support == 2) s2.push("Left Kemalists");
    else su.push("Left Kemalists");
    if (Q.kemalist_marxists_support == 1) s1.push("Kemalist Marxists");
    else if (Q.kemalist_marxists_support == 2) s2.push("Kemalist Marxists");
    else su.push("Kemalist Marxists");
    if (Q.orthodox_kemalists_support == 1) s1.push("Orthodox Kemalists");
    else if (Q.orthodox_kemalists_support == 2) s2.push("Orthodox Kemalists");
    else su.push("Orthodox Kemalists");
    if (!Q.right_kemalist_split) {
        if (Q.right_kemalists_support == 1) s1.push("Right Kemalists");
        else if (Q.right_kemalists_support == 2) s2.push("Right Kemalists");
        else su.push("Right Kemalists");
    }
    Q.candidate_1_supporters = s1.length > 0 ? s1.join(", ") : "None";
    Q.candidate_2_supporters = s2.length > 0 ? s2.join(", ") : "None";
    Q.undecided_factions = su.length > 0 ? su.join(", ") : "";
}

// Portrait mapping
Q.candidate_1_portrait = "";
Q.candidate_2_portrait = "";
if (Q.congress_candidate_1 == "ecevit") Q.candidate_1_portrait = "img/portraits/ecevit3.jpg";
if (Q.congress_candidate_1 == "inonu") Q.candidate_1_portrait = "img/portraits/IsmetInonu.jpg";
if (Q.congress_candidate_1 == "kirikoglu") Q.candidate_1_portrait = "img/portraits/KamilKirikoglu.jpg";
if (Q.congress_candidate_1 == "eyuboglu") Q.candidate_1_portrait = "img/portraits/OrhanEyuboglu.jpeg";
if (Q.congress_candidate_2 == "ecevit") Q.candidate_2_portrait = "img/portraits/ecevit3.jpg";
if (Q.congress_candidate_2 == "inonu") Q.candidate_2_portrait = "img/portraits/IsmetInonu.jpg";
if (Q.congress_candidate_2 == "kirikoglu") Q.candidate_2_portrait = "img/portraits/KamilKirikoglu.jpg";
if (Q.congress_candidate_2 == "eyuboglu") Q.candidate_2_portrait = "img/portraits/OrhanEyuboglu.jpeg";

// Candidate name mapping
Q.candidate_1_name = "";
Q.candidate_2_name = "";
if (Q.congress_candidate_1 == "ecevit") Q.candidate_1_name = "Bülent Ecevit";
if (Q.congress_candidate_1 == "inonu") Q.candidate_1_name = "İsmet İnönü";
if (Q.congress_candidate_1 == "kirikoglu") Q.candidate_1_name = "Kamil Kırıkoğlu";
if (Q.congress_candidate_1 == "eyuboglu") Q.candidate_1_name = "Orhan Eyüboğlu";
if (Q.congress_candidate_2 == "ecevit") Q.candidate_2_name = "Bülent Ecevit";
if (Q.congress_candidate_2 == "inonu") Q.candidate_2_name = "İsmet İnönü";
if (Q.congress_candidate_2 == "kirikoglu") Q.candidate_2_name = "Kamil Kırıkoğlu";
if (Q.congress_candidate_2 == "eyuboglu") Q.candidate_2_name = "Orhan Eyüboğlu";

// Leader portrait (when no congress)
Q.leader_portrait = "";
if (Q.CHP_party_leader == "İnönü" || Q.CHP_party_leader == "inonu") Q.leader_portrait = "img/portraits/IsmetInonu.jpg";
if (Q.CHP_party_leader == "Ecevit" || Q.CHP_party_leader == "ecevit") Q.leader_portrait = "img/portraits/ecevit3.jpg";
!}

= The Party

[? if congress_upcoming : {!<div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px;">
<div style="text-align: center; width: 45%;">
<img src="!}[+ candidate_1_portrait +]{!" style="width: 70px; height: 70px; border-radius: 50%; border: 3px solid #ca1010; object-fit: cover;">
<div style="font-weight: bold; font-size: 0.85em; margin-top: 4px; color: #ca1010;">!}[+ candidate_1_name +]{!</div>
<div style="font-size: 0.7em; margin-top: 2px;">!}[+ candidate_1_supporters +]{!</div>
<div style="font-size: 0.75em; font-weight: bold; margin-top: 2px;">!}[+ candidate_1_seats +]{! seats</div>
</div>
<div style="text-align: center; width: 45%;">
<img src="!}[+ candidate_2_portrait +]{!" style="width: 70px; height: 70px; border-radius: 50%; border: 3px solid #9e9e9e; object-fit: cover;">
<div style="font-weight: bold; font-size: 0.85em; margin-top: 4px; color: #9e9e9e;">!}[+ candidate_2_name +]{!</div>
<div style="font-size: 0.7em; margin-top: 2px;">!}[+ candidate_2_supporters +]{!</div>
<div style="font-size: 0.75em; font-weight: bold; margin-top: 2px;">!}[+ candidate_2_seats +]{! seats</div>
</div>
</div>!} ?]
[? if congress_upcoming and undecided_factions : {!<div style="text-align: center; font-size: 0.7em; color: #888; margin-bottom: 6px;"><em>Undecided: !}[+ undecided_factions +]{!</em></div>!} ?]

[? if not congress_upcoming : {!<div style="text-align: center; margin-bottom: 10px;">
<img src="!}[+ leader_portrait +]{!" style="width: 80px; height: 80px; border-radius: 50%; border: 3px solid #E3000F; object-fit: cover;">
<div style="font-weight: bold; font-size: 0.9em; margin-top: 4px;">Party Leader: !}[+ CHP_party_leader +]{!</div>
</div>!} ?]

= Congress Seat Distribution

{!<svg id="party-parliament" style="width: 100%; height: 130px;"> </svg>!}

{!<div style="font-size: 0.75em; margin-top: 4px;">
<span style="color: #701616;">&#9632;</span> Kemalist Marxists: !}[+ km_congress_seats +]{! (<em>!}[+ km_strength_label +]{!</em>) &nbsp;
<span style="color: #c76082;">&#9632;</span> Left Kemalists: !}[+ lk_congress_seats +]{! (<em>!}[+ lk_strength_label +]{!</em>)<br>
<span style="color: #5a5f63;">&#9632;</span> Orthodox Kemalists: !}[+ ok_congress_seats +]{! (<em>!}[+ ok_strength_label +]{!</em>) &nbsp;!}
[? if not right_kemalist_split : {!<span style="color: #353057;">&#9632;</span> Right Kemalists: !}[+ rk_congress_seats +]{! (<em>!}[+ rk_strength_label +]{!</em>)!} ?]
{!</div>!}

