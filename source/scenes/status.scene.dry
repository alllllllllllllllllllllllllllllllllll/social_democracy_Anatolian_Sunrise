title: Status
new-page: true
is-special: true
on-arrival: {!
// Recalculate economic values from base + modifier before displaying
// This ensures economy card changes are reflected immediately
Q.inflation = (Q.base_inflation || 0) + (Q.inflation_modifier || 0);
Q.economic_growth = (Q.base_growth || 0) + (Q.growth_modifier || 0);
Q.unemployed = (Q.base_unemployment || 0) + (Q.unemployment_modifier || 0);

// Format economic indicators with proper fallbacks only for display
Q.unemployed_2 = (Q.unemployed !== undefined && Q.unemployed !== null) ? Q.unemployed.toFixed(1) : '4.6';
Q.inflation_2 = (Q.inflation !== undefined && Q.inflation !== null) ? Q.inflation.toFixed(1) : '15.3';
Q.economic_growth_2 = (Q.economic_growth !== undefined && Q.economic_growth !== null) ? Q.economic_growth.toFixed(1) : '9.2';

// Format production indices
Q.industrial_index_formatted = Q.industrial_production_index ? Q.industrial_production_index.toFixed(1) : '100.0';
Q.agricultural_index_formatted = Q.agricultural_production_index ? Q.agricultural_production_index.toFixed(1) : '100.0';

// Format agricultural market data
Q.agricultural_prices_formatted = Q.agricultural_product_prices ? Q.agricultural_product_prices.toFixed(2) : '1.00';

// Format forex pressure and determine status
Q.forex_pressure_formatted = Q.forex_pressure ? Q.forex_pressure.toFixed(1) : '45.0';
if (Q.forex_pressure <= 20) {
    Q.forex_pressure_status = "Low";
} else if (Q.forex_pressure > 20 && Q.forex_pressure <= 40) {
    Q.forex_pressure_status = "Manageable";
} else if (Q.forex_pressure > 40 && Q.forex_pressure <= 60) {
    Q.forex_pressure_status = "Straining";
} else if (Q.forex_pressure > 60 && Q.forex_pressure <= 80) {
    Q.forex_pressure_status = "Damaging";
} else if (Q.forex_pressure > 80) {
    Q.forex_pressure_status = "Crushing";
}

// Debug: Log the actual values
console.log("=== Economic Status Debug ===");
console.log("Current year:", Q.year, "month:", Q.month, "week:", Q.week);
console.log("Inflation - base:", Q.base_inflation, "modifier:", Q.inflation_modifier, "final:", Q.inflation, "formatted:", Q.inflation_2);
console.log("Unemployment - base:", Q.base_unemployment, "modifier:", Q.unemployment_modifier, "final:", Q.unemployed, "formatted:", Q.unemployed_2);
console.log("Growth - base:", Q.base_growth, "modifier:", Q.growth_modifier, "final:", Q.economic_growth, "formatted:", Q.economic_growth_2);
console.log("Industrial Index:", Q.industrial_production_index);
console.log("Agricultural Index:", Q.agricultural_production_index);
console.log("Agricultural Prices:", Q.agricultural_product_prices, "Status:", Q.agricultural_price_status);
console.log("Historical base values - Inflation:", Q.historical_inflation[Q.year], "Unemployment:", Q.historical_unemployment[Q.year], "GDP:", Q.historical_gdp_growth[Q.year]);
console.log("==============================");
if (typeof Q.chp_seats === 'undefined') {
    Q.chp_seats = 143;
    Q.z_seats = 224;
    Q.TIP_seats = 2;
    Q.CGP_seats = 15;
    Q.DP_seats = 36;
    Q.MSP_seats = 0;
    Q.MHP_seats = 1;
    Q.other_seats = 29;
}
if (typeof Q.sapd_seats === 'undefined') {
    Q.sapd_seats = 0;
}
if (typeof Q.majority_threshold === 'undefined') {
    Q.majority_threshold = 226;
}
if (typeof Q.right_kemalist_split === 'undefined') {
    Q.right_kemalist_split = 0;
}
if (typeof Q.right_kemalist_deal === 'undefined') {
    Q.right_kemalist_deal = 0;
}
if (typeof Q.right_kemalists_resign === 'undefined') {
    Q.right_kemalists_resign = 0;
}

// Initialize per-quarter strengths if they don't exist (backward compatibility with saves)
if (typeof Q.q0_km_str === 'undefined') {
    var _qWInit = [0.20, 0.15, 0.25, 0.20, 0.10, 0.10];
    var _fKeysInit = ['km', 'lk', 'ok', 'rk'];
    var _fGlobalsInit = ['kemalist_marxists_strength', 'left_kemalists_strength', 'orthodox_kemalists_strength', 'right_kemalists_strength'];
    for (var _fii = 0; _fii < 4; _fii++) {
        var _val = Q[_fGlobalsInit[_fii]] || 0;
        for (var _qii = 0; _qii < 6; _qii++) {
            Q['q' + _qii + '_' + _fKeysInit[_fii] + '_str'] = _val;
        }
        Q['_last_' + _fKeysInit[_fii] + '_str'] = _val;
    }
}

// Per-quarter faction strengths are the source of truth and are only
// modified by direct assignment in game events/advisors (not by global sync).
// Global faction strengths are normalized independently by post_event.

// Compute strength labels from weighted averages of per-quarter faction strengths
// Quarter weights: Grassroots(20%), Base(15%), Bureaucracy(25%), TBMM(20%), Intelligentsia(10%), Local(10%)
// Scale: 0-0.5 Nonexistant, 0.5-1.5 Very weak, 1.5-2.5 Weak,
// 2.5-3.5 Medium, 3.5-4.5 High, 4.5-5.5 Very High, 5.5+ & > others combined = Hegemonic
var _qWgts = [0.20, 0.15, 0.25, 0.20, 0.10, 0.10];
var _kmAvg = 0, _lkAvg = 0, _okAvg = 0, _rkAvg = 0;
for (var _qi = 0; _qi < 6; _qi++) {
    _kmAvg += _qWgts[_qi] * (Q['q' + _qi + '_km_str'] || 0);
    _lkAvg += _qWgts[_qi] * (Q['q' + _qi + '_lk_str'] || 0);
    _okAvg += _qWgts[_qi] * (Q['q' + _qi + '_ok_str'] || 0);
    _rkAvg += _qWgts[_qi] * (Q['q' + _qi + '_rk_str'] || 0);
}

function _strengthLabel(score, myAvg, othersAvg) {
    if (score >= 5.5 && myAvg > othersAvg) return "Hegemonic";
    if (score >= 4.5) return "Very High";
    if (score >= 3.5) return "High";
    if (score >= 2.5) return "Medium";
    if (score >= 1.5) return "Weak";
    if (score >= 0.5) return "Very weak";
    return "Nonexistant";
}

var _rkAvgActive = Q.right_kemalist_split ? 0 : _rkAvg;

Q.km_strength_label = _strengthLabel(_kmAvg, _kmAvg, _lkAvg + _okAvg + _rkAvgActive);
Q.lk_strength_label = _strengthLabel(_lkAvg, _lkAvg, _kmAvg + _okAvg + _rkAvgActive);
Q.ok_strength_label = _strengthLabel(_okAvg, _okAvg, _kmAvg + _lkAvg + _rkAvgActive);
Q.rk_strength_label = Q.right_kemalist_split ? "Nonexistant" : _strengthLabel(_rkAvg, _rkAvg, _kmAvg + _lkAvg + _okAvg);
!}

