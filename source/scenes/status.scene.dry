= Internal Factions of the CHP

{!<span class="tooltip-text" title="Marxists within the party desire a realignment of the party alongside Socialist elements. Even though many intellectuals such as Tevfik Rüştü Aras and Doğan Avcıoğlu subscribe to this faction, there is no central organization nor a figure that leads the Marxist camp, largely due to ideological differences. However the general secretary, Kamil Kırıkoğlu, is the most prominent member in the party.">Kemalist Marxists</span>!} strength: [+ km_strength_label +], dissent: [+ kemalist_marxists_dissent : dissent +]

{!<span class="tooltip-text" title="Left Kemalists aka the Left of Center movement is a movement within CHP led by poet Bülent Ecevit which wishes to compliment the Progressive nature of the party with Social Democracy and in face of the growing urban working class, instead of swimming against the current, desires to lead the stream.">Left Kemalists</span>!} strength: [+ lk_strength_label +], dissent: [+ left_kemalists_dissent : dissent +]

{!<span class="tooltip-text" title="CHP was created as a middle class party to reinforce the Kemalist and the semi-bourgeoisie revolution of the military intelligentsia. Mostly the remnants of the one party era and lead by the illustrious right-man in command of Ataturk, İsmet İnönü, the Orthodox Kemalists reject any intrusion into the Left in fears of CHP losing its identity as the party that gave birth to the Turkish Republic, as a nation-state found on Corporatist principles.">Orthodox Kemalists</span>!} strength: [+ ok_strength_label +], dissent: [+ orthodox_kemalists_dissent : dissent +]

{!<span class="tooltip-text" title="Seeing the rising Left of Center movement as a pivot to Socialism and Communism, the Right Kemalists advocate for an increased emphasis on Kemalist Nationalism and Corporatism which would serve as a third and moderate alternative to the two wings of Turkish politics, the &quot;unnational&quot; left and the &quot;backward&quot; right. Even though Right Kemalists have formed a party led by Turhan Feyzioğlu, they still have many sympathizers within the party.">Right Kemalists</span>!} strength: [+ rk_strength_label +], dissent: [+ right_kemalists_dissent : dissent +]
[? if right_kemalist_split : {!<span style="color: #7A3C00;">Following Ecevit's ascension, the Right Kemalist faction has left the party to join the non-socialist opposition.</span>!} ?]
[? if not right_kemalist_split and right_kemalist_deal : {!<span style="color: #7A3C00;">Satır's compromise keeps the Right Kemalists inside the CHP—at least for now.</span>!} ?]

[? if neorevisionism > 0 : Neorevisionist strength: [+ neorevisionist_strength : strength +], dissent: [+ neorevisionist_dissent : dissent +] ?]


@paramilitaries
on-arrival: {!
// Recalculate paramilitary force effectiveness (strength × militancy)
Q.far_left_force = 0;
Q.far_right_force = 0;
Q.separatist_force = 0;
Q.state_force = 0;
Q.democracy_force = 0;

// Separatist forces calculation (strength × militancy)
if (Q.kurdish_radicalism >= 0.69) {
    Q.pkk_formed = 1;
    Q.pkk_strength = Q.pkk_base_strength * (2 * Q.kurdish_political_consciousness);
    Q.pkk_force = Q.pkk_strength * Q.pkk_militancy;
    Q.separatist_force += Q.pkk_force;
} else {
    Q.pkk_formed = 0;
    Q.pkk_strength = 0;
    Q.pkk_force = 0;
}

// Far left forces calculation (strength × militancy)
if (!Q.thkpc_destroyed) {
    Q.thkpc_force = Q.thkpc_strength * Q.thkpc_militancy;
    Q.far_left_force += Q.thkpc_force;
} else {
    Q.thkpc_strength = 0;
}
if (Q.devyol_formed) {
    Q.devyol_force = Q.devyol_strength * Q.devyol_militancy;
    Q.far_left_force += Q.devyol_force;
}
if (Q.tkpml_formed) {
    Q.tkpml_force = Q.tkpml_strength * Q.tkpml_militancy;
    Q.far_left_force += Q.tkpml_force;
}

// Far right forces calculation (strength × militancy)
Q.grey_wolves_force = Q.grey_wolves_strength * Q.grey_wolves_militancy;
Q.far_right_force += Q.grey_wolves_force;

if (Q.raiders_formed) {
    Q.raiders_force = Q.raiders_strength * Q.raiders_militancy;
    Q.far_right_force += Q.raiders_force;
}

Q.tit_force = Q.tit_strength * Q.tit_militancy;
Q.far_right_force += Q.tit_force;

// State forces calculation (strength × militancy)
Q.police_force = Q.police_strength * Q.police_militancy;
Q.interior_police_force = Q.interior_police_strength * Q.interior_police_militancy; // 0 for Turkish context
Q.prussian_police_force = Q.prussian_police_strength * Q.prussian_police_militancy; // 0 for Turkish context

Q.state_force = Q.police_force + Q.interior_police_force + Q.prussian_police_force;

// Democratic forces (state forces when not controlled by extremists)
Q.democracy_force = Q.state_force;

// Total forces for percentage calculation
Q.total_forces = Q.far_left_force + Q.far_right_force + Q.separatist_force + Q.state_force;

// Convert to percentages
if (Q.total_forces > 0) {
    Q.far_left_force_percent = Math.round((Q.far_left_force / Q.total_forces) * 100);
    Q.far_right_force_percent = Math.round((Q.far_right_force / Q.total_forces) * 100);
    Q.separatist_force_percent = Math.round((Q.separatist_force / Q.total_forces) * 100);
    Q.state_force_percent = Math.round((Q.state_force / Q.total_forces) * 100);
    Q.democracy_force_percent = Q.state_force_percent;
    
    // Individual organization force percentages
    if (!Q.thkpc_destroyed) {
        Q.thkpc_force_percent = Math.round((Q.thkpc_force / Q.total_forces) * 100);
    }
    if (Q.pkk_formed) {
        Q.pkk_force_percent = Math.round((Q.pkk_force / Q.total_forces) * 100);
    }
    if (Q.devyol_formed) {
        Q.devyol_force_percent = Math.round((Q.devyol_force / Q.total_forces) * 100);
    }
    if (Q.tkpml_formed) {
        Q.tkpml_force_percent = Math.round((Q.tkpml_force / Q.total_forces) * 100);
    }
    Q.grey_wolves_force_percent = Math.round((Q.grey_wolves_force / Q.total_forces) * 100);
    if (Q.raiders_formed) {
        Q.raiders_force_percent = Math.round((Q.raiders_force / Q.total_forces) * 100);
    }
    Q.tit_force_percent = Math.round((Q.tit_force / Q.total_forces) * 100);
    
    Q.police_force_percent = Math.round((Q.police_force / Q.total_forces) * 100);
    Q.interior_police_force_percent = Math.round((Q.interior_police_force / Q.total_forces) * 100);
    Q.prussian_police_force_percent = Math.round((Q.prussian_police_force / Q.total_forces) * 100);
}

// Format strength values for display
if (Q.thkpc_strength) {
    Q.thkpc_strength_2 = Q.thkpc_strength.toFixed(1);
}	
if (Q.tkpml_strength) {
    Q.tkpml_strength_2 = Q.tkpml_strength.toFixed(1);
}
if (Q.devyol_strength) {
    Q.devyol_strength_2 = Q.devyol_strength.toFixed(1);
}
if (Q.police_strength) {
    Q.police_strength_2 = Q.police_strength.toFixed(1);
}
if (Q.pkk_strength) {
    Q.pkk_strength_2 = Q.pkk_strength.toFixed(1);
}
if (Q.grey_wolves_strength) {
    Q.grey_wolves_strength_2 = Q.grey_wolves_strength.toFixed(1);
}
if (Q.raiders_strength) {
    Q.raiders_strength_2 = Q.raiders_strength.toFixed(1);
}
if (Q.tit_strength) {
    Q.tit_strength_2 = Q.tit_strength.toFixed(1);
}

// Convert army strength values (0-1) to descriptive text
function getStrengthDescription(value) {
    if (value >= 0.8) return "Excellent";
    else if (value >= 0.6) return "Good";
    else if (value >= 0.5) return "Sufficient";
    else if (value >= 0.4) return "Adequate";
    else if (value >= 0.2) return "Poor";
    else if (value >= 0.1) return "Decrepit";
    else return "Horrible";
}

Q.army_land_desc = getStrengthDescription(Q.army_land_strength);
Q.army_naval_desc = getStrengthDescription(Q.army_naval_strength);
Q.army_aerial_desc = getStrengthDescription(Q.army_aerial_strength);
!}

